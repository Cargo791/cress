                <option>GBP (£)</option>

            </select>

            <select
            class="w-full p-3 rounded-lg bg-slate-800 border border-white/10">

                <option>Dark Theme</option>
                <option>Light Theme</option>

            </select>

        </div>
    <!-- FIXED BOTTOM NAVIGATION BAR -->
    <nav class="sticky bottom-0 left-0 right-0 bg-gradient-to-t from-deep to-mid border-t border-white/10 z-50">
      <div class="max-w-7xl mx-auto px-4 py-3 flex justify-around items-center text-slate-300 text-xs">
        <button onclick="openSettings()"
class="flex flex-col items-center gap-1 hover:text-accentA transition">

    <span class="text-2xl">⚙️</span>
    <span>Settings</span>

</button>
        <button class="flex flex-col items-center gap-1 hover:text-accentA transition relative">
          <span class="text-2xl">🔔</span>
          <span>Notifications</span>
          <span class="absolute -top-1 -right-1 bg-red-500 text-white text-[10px] px-1.5 rounded-full">0</span>
        </button>
          <a href="/https://crestpointcapital.ct.ws" class="flex flex-col items-center gap-1 text-accentA">

  <span class="text-3xl">🏠</span>

  <span class="font-medium">Home</span>

</a>
        <button class="flex flex-col items-center gap-1 hover:text-accentA transition relative">
          <span class="text-2xl">💬</span>
          <span>Support</span>
          <span class="absolute -top-1 -right-1 w-5 h-5 bg-green-500 rounded-full animate-pulse"></span>
        </button>
       <a href="https://crestpointcapital.ct.ws" class="flex flex-col items-center gap-1 hover:text-red-400 transition">
  <span class="text-2xl">🚪</span>
  <span>Logout</span>
</a>
      </div>
    </nav>
  </div>
        <!-- VERIFICATION -->

        <div class="glass rounded-2xl p-5">

            <h3 class="text-lg font-semibold text-accentA mb-4">

                📄 Verification

            </h3>

            <div class="flex items-center justify-between">

                <span>Identity Verification</span>

                <span class="text-emerald-400 font-semibold">
                    ✔ Verified
                </span>

            </div>

            <button
            class="mt-5 w-full p-3 rounded-lg bg-slate-800 hover:bg-slate-700">

                Upload New ID

            </button>

        </div>

        <!-- SUPPORT -->

        <div class="glass rounded-2xl p-5">

            <h3 class="text-lg font-semibold text-accentA mb-4">

                📞 Support

            </h3>

            <button
            class="w-full mb-3 p-3 rounded-lg bg-slate-800 hover:bg-slate-700">

