    </div>

</div>

<!-- DARK OVERLAY -->

<div id="settingsOverlay"
class="fixed inset-0 bg-black/60 hidden z-[998]"
onclick="closeSettings()">

</div>
  <script>
// COPY ADDRESS FUNCTION
['btc','eth','bnb','sol'].forEach(id => {
  const el = document.getElementById(id+'-address');
  el.addEventListener('click', () => {
    navigator.clipboard.writeText(el.textContent).then(() => {
      alert(id.toUpperCase() + ' address copied!');
    });
  });
});

// WITHDRAW FUNCTION
function handleWithdraw() {
  const message = document.getElementById('withdraw-message');
  message.classList.remove('hidden');
}
// COPY ADDRESS FUNCTION
['btc','eth','bnb','sol'].forEach(id => {
  const el = document.getElementById(id+'-address');
  el.addEventListener('click', () => {
    navigator.clipboard.writeText(el.textContent).then(() => {
      alert(id.toUpperCase() + ' address copied!');
    });
  });
});
<script>

function openSettings(){

    document
        .getElementById("settingsPanel")
        .classList.remove("translate-x-full");

    document
        .getElementById("settingsOverlay")
        .classList.remove("hidden");

}

function closeSettings(){

    document
        .getElementById("settingsPanel")
        .classList.add("translate-x-full");

    document
        .getElementById("settingsOverlay")
        .classList.add("hidden");

}

</script>
</script>
