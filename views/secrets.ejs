<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>CREST POINT CAPITAL — Dashboard</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            navy:'#0b1834',
            mid:'#071a38',
            deep:'#04122a',
            accentA:'#3ddcff',
            accentB:'#0a84ff'
          }
        }
      }
    }
  </script>

  <style>
    /* Glassmorphism */
    .glass {
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,.03));
      backdrop-filter: blur(14px);
      border: 1px solid rgba(255,255,255,.08);
    }

    /* Scrollbar hide */
    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }
    .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    /* Shake animation */
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-8px); }
      50% { transform: translateX(8px); }
      75% { transform: translateX(-8px); }
    }
    .animate-shake {
      animation: shake 0.4s ease-in-out;
    }

    /* Padding so content isn't hidden under fixed nav */
    main {
      padding-bottom: 120px;
    }

    /* PIN overlay */
   
  </style>
</head>

<body class="bg-gradient-to-b from-navy via-mid to-deep text-slate-100 min-h-screen overflow-y-auto">

  <!-- PIN SCREEN -->
  

  <!-- DASHBOARD CONTENT -->
  <div id="dashboard">
    <!-- HEADER -->
    <header class="border-b border-white/10">
      <div class="max-w-7xl mx-auto px-6 py-5 flex justify-between items-center">
        <div>
          <h1 class="text-xl font-semibold tracking-wide">CREST POINT CAPITAL</h1>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-sm text-slate-300">Welcome, <strong><%= name %></strong></span>
          <img src="/logo.jpeg.png" alt="Unity Trust Logo" class="h-9 w-9 rounded-full border border-white/20">
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-10 space-y-10">
      <!-- MULTIPLE ACCOUNT CARDS - Horizontal Scroll Carousel -->
      <div class="relative">
        <div class="flex overflow-x-auto snap-x snap-mandatory gap-6 pb-4 scrollbar-hide">
          <!-- Card 1: Savings -->
          <div class="glass rounded-3xl p-7 min-w-[85vw] md:min-w-[420px] snap-center flex-shrink-0 relative overflow-y-auto shadow-2xl">
            <p class="text-xs tracking-widest text-slate-400 uppercase">Available Balance</p>
            <h3 class="text-5xl md:text-6xl font-bold mt-4 tracking-tight">$820,000</h3>
            <div class="mt-6 space-y-2 text-sm">
              <p class="text-slate-400">ACCOUNT NUMBER</p>
              <p class="tracking-widest text-slate-200 font-medium">•••• 7158</p>
            </div>
            <div class="grid grid-cols-2 gap-6 mt-10 text-xs">
              <div>
                <p class="text-slate-400 tracking-widest uppercase">TOTAL CREDIT<br>JUL 2026</p>
                <p class="text-slate-200 mt-1 font-medium">$0.00</p>
              </div>
              <div>
                <p class="text-slate-400 tracking-widest uppercase">TOTAL DEBIT<br>JAN 2025</p>
                <p class="text-slate-200 mt-1 font-medium">$0.00</p>
              </div>
            </div>
            <div class="absolute inset-0 bg-gradient-to-br from-accentA/5 to-transparent pointer-events-none"></div>
          </div>

         

        <!-- Carousel indicators -->
        <div class="hidden md:flex justify-center mt-4 gap-3">
          <div class="w-3 h-3 rounded-full bg-accentA"></div>
          <div class="w-3 h-3 rounded-full bg-white/30"></div>
          <div class="w-3 h-3 rounded-full bg-white/30"></div>
          <div class="w-3 h-3 rounded-full bg-white/30"></div>
          <div class="w-3 h-3 rounded-full bg-white/30"></div>
        </div>
      </div>
      <form class="glass p-6 rounded-xl space-y-4">
  <h3 class="font-semibold text-lg">Withdraw</h3>
  
  <input type="text" placeholder="Wallet / Bank Details"
    class="w-full p-2 rounded-md bg-slate-800 border border-slate-700 text-slate-200" />

  <input type="number" placeholder="Amount (USD)"
    class="w-full p-2 rounded-md bg-slate-800 border border-slate-700 text-slate-200" />

  <button type="button" onclick="handleWithdraw()"
    class="w-full bg-gradient-to-r from-accentA to-accentB text-black py-2 rounded font-bold">
    Withdraw
  </button>

  <p id="withdraw-message" class="text-sm text-red-400 hidden">
    Account need to be up to a $1m before you'll be able to withdraw.
  </p>
</form>

      <!-- STATEMENT SECTION -->
      <div class="glass rounded-2xl overflow-y-auto">
        <div class="p-6 border-b border-white/10 flex items-center justify-between">
          <div>
            <h3 class="text-lg font-semibold">Savings Statement</h3>
            <p class="text-sm text-slate-400 mt-1">Savings Account Statement #001185707158</p>
          </div>
          <button class="w-12 h-12 rounded-full bg-gradient-to-br from-accentA/30 to-accentB/30 flex items-center justify-center hover:from-accentA/50 hover:to-accentB/50 transition">
            <span class="text-2xl">▶️</span>
          </button>
        </div>

        <!-- Transaction table -->
        <div class="p-6">
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
            <div class="text-sm text-slate-300">
              Show 
              <select class="bg-slate-800 border border-white/20 rounded px-2 py-1 text-sm">
                <option>10</option>
                <option>25</option>
                <option>50</option>
              </select> 
              entries
            </div>
            <div>
              <input type="text" placeholder="Search..." class="bg-slate-800/70 border border-white/10 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-accentA/50 w-48" />
            </div>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="text-slate-400 border-b border-white/10">
                <tr>
                  <th class="py-4 text-left font-normal">Date</th>
                  <th class="py-4 text-left font-normal">Type</th>
                  <th class="py-4 text-left font-normal">Amount</th>
                  <th class="py-4 w-10"></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                <!-- Transactions rows (10 sample rows) -->
                <script>
                  const transactions = [
                    {date:"28th January, 2026", type:"Credit", amount:"$12,450.00", desc:"Salary deposit - TechCorp Ltd", ref:"TRX-20260128-3194"},
                    {date:"25th November, 2025", type:"Debit", amount:"$3,875.60", desc:"Online purchase - Electronics store", ref:"TRX-20260125-0821"},
                    {date:"19th December, 2025", type:"Credit", amount:"$45,000.00", desc:"Investment return - Portfolio #A472", ref:""},
                    {date:"15th August, 2025", type:"Debit", amount:"$1,920.00", desc:"Utility bill payment - Electricity", ref:""},
                    {date:"10th May, 2025", type:"Debit", amount:"$8,250.75", desc:"Transfer to family account", ref:""},
                    {date:"7th Narch, 2025", type:"Credit", amount:"$22,300.00", desc:"Freelance payment received", ref:""},
                    {date:"3rd January, 2026", type:"Debit", amount:"$4,180.00", desc:"Rent payment - January", ref:""},
                    {date:"30th December, 2025", type:"Credit", amount:"$18,750.00", desc:"Bonus payout", ref:""},
                    {date:"27th January, 2024", type:"Debit", amount:"$2,640.50", desc:"Christmas shopping - Various", ref:""},
                    {date:"20th December, 2023", type:"Credit", amount:"$9,875.00", desc:"Client payment - Project X", ref:""}
                  ];

                  for(const t of transactions){
                    document.write(`
                      <tr class="group hover:bg-white/5 transition">
                        <td class="py-4">${t.date}</td>
                        <td class="py-4 ${t.type==="Credit"?"text-emerald-400":"text-red-400"}">${t.type}</td>
                        <td class="py-4 font-medium">${t.amount}</td>
                        <td class="py-4">
                          <button onclick="this.closest('tr').nextElementSibling.classList.toggle('hidden'); this.querySelector('span').textContent = this.closest('tr').nextElementSibling.classList.contains('hidden') ? '+' : '−';"
                            class="w-8 h-8 rounded-full bg-blue-600/30 hover:bg-blue-600/50 flex items-center justify-center text-lg font-bold transition">
                            <span>+</span>
                          </button>
                        </td>
                      </tr>
                      <tr class="hidden bg-slate-900/40">
                        <td colspan="4" class="p-5 text-slate-300 text-sm">
                          <div class="space-y-2">
                            ${t.ref?`<p><strong>Reference:</strong> ${t.ref}</p>`:""}
                            <p><strong>Description:</strong> ${t.desc}</p>
                          </div>
                        </td>
                      </tr>
                    `)
                  }
                </script>
              </tbody>
            </table>
          </div>

          <!-- Pagination -->
          <div class="mt-6 flex justify-between items-center text-sm text-slate-400">
            <span>Showing 1 to 10 of 38 entries</span>
            <div class="flex gap-2">
              <button class="px-3 py-1 bg-white/5 rounded hover:bg-white/10 disabled:opacity-50" disabled>Previous</button>
              <button class="px-3 py-1 bg-white/5 rounded hover:bg-white/10">Next</button>
            </div>
          </div>
        </div>
      </div>

    </main>

    <!-- FOOTER -->
    <footer class="text-center text-xs text-slate-500 py-8">
      ©️ 2025 Unity Trust — All rights reserved
    </footer>
<!-- SETTINGS PANEL -->

<div id="settingsPanel"
class="fixed top-0 right-0 h-full w-full md:w-[430px]
bg-gradient-to-b from-[#071a38] to-[#04122a]
shadow-2xl transform translate-x-full
transition-transform duration-300
z-[999] overflow-y-auto">

